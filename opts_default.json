    "git": {
      "enable_all": false,
      "components": {
        "blame": false,
        "codediff": false,
        "mini_diff": false
      }
    },
    "util": {
      "enable_all": false,
      "components": {
        "minimap": false,
        "neoclip": false,
        "comment_box": false,
        "flash": false,
        "grug_far": false,
        "mini_surround": false,
        "portal": false,
        "grapple": false,
        "snacks": false
      }
    },
    "ai": {
      "enable_all": false,
      "components": {
        "copilot": false,
        "codecomponion": false
      }
    },
    "leetcode": false,
    "tex": false
  }
}
