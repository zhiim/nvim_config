{
  "mode": {
    "chosen": 1,
    "choices": ["minimal", "IDE"]
  },
  "picker": {
    "chosen": 1,
    "choices": ["fzf_lua", "telescope"]
  },
  "tab": {
    "chosen": 1,
    "choices": ["barbar", "bufferline", "tabby"]
  },
  "explorer": {
    "chosen": 1,
    "choices": ["nvimtree", "neotree", "fyler"]
  },
  "settings": {
    "proxy": "",
    "bash_path": "",
    "gemini_api_key": ""
  },
  "plugins": {
    "theme": {
      "enabled": false,
      "chosen": 1,
      "choices": [
        "github",
        "catppuccin",
        "nightfox",
        "tokyonight",
        "kanagawa",
        "onedark",
        "everforest",
        "onenord",
        "nordic",
        "gruvbox",
        "material"
      ],
      "theme_variants": {
        "github": {
          "chosen": 3,
          "choices": [
            "github_dark",
            "github_light",
            "github_dark_dimmed",
            "github_dark_default",
            "github_light_default",
            "github_dark_high_contrast",
            "github_light_high_contrast",
            "github_dark_colorblind",
            "github_light_colorblind",
            "github_dark_tritanopia",
            "github_light_tritanopia"
          ]
        },
        "catppuccin": {
          "chosen": 3,
          "choices": [
            "catppuccin-latte",
            "catppuccin-frappe",
            "catppuccin-macchiato",
            "catppuccin-mocha"
          ]
        },
        "nightfox": {
          "chosen": 3,
          "choices": [
            "carbonfox",
            "dawnfox",
            "dayfox",
            "duskfox",
            "nightfox",
            "nordfox",
            "terafox"
          ]
        },
        "tokyonight": {
          "chosen": 2,
          "choices": [
            "tokyonight-night",
            "tokyonight-storm",
            "tokyonight-day",
            "tokyonight-moon"
          ]
        },
        "kanagawa": {
          "chosen": 1,
          "choices": ["kanagawa-wave", "kanagawa-dragon", "kanagawa-lotus"]
        },
        "onedark": {
          "chosen": 1,
          "choices": ["onedark", "onelight", "onedark_vivid", "onedark_dark"]
        },
        "material": {
          "chosen": 1,
          "choices": ["darker", "lighter", "oceanic", "palenight", "deep ocean"]
        }
      }
    },
    "ui": {
      "enable_all": false,
      "components": {
        "dashboard": false,
        "dropbar": false,
        "lualine": false,
        "noice": false,
        "ufo": false,
        "statuscol": false,
        "smear_cursor": false,
        "tiny_inline_diagnostic": false,
        "tiny_glimmer": false,
        "nvim_colorizer": false,
        "todo_comments": false
      }
    },
    "language": {
      "enable_all": false,
      "components": {
        "basic": {
          "enabled": false,
          "cmp": {
            "chosen": 1,
            "choices": ["blink_cmp", "nvim_cmp"]
