            "use_all": false,
            "servers": {
              "clangd": false,
              "taplo": false,
              "cmake": false,
              "basedpyright": false,
              "ruff": false,
              "lua_ls": false
            }
          },
          "formatter": {
            "use_all": false,
            "formatters": {
              "stylua": false,
              "prettier": false,
              "clang-format": false,
              "cmake_format": false,
              "taplo": false
            }
          },
          "linter": {
            "use_all": false,
            "linters": {
              "jsonlint": false,
              "yamllint": false
            }
          },
          "treesitter": {
            "use_all": false,
            "parsers": {
              "bash": false,
              "c": false,
              "cpp": false,
              "python": false,
              "lua": false,
              "luadoc": false,
              "markdown": false,
              "markdown_inline": false,
              "yaml": false,
              "json": false,
              "toml": false,
              "diff": false,
              "vim": false,
              "vimdoc": false
            }
          }
        },
        "debug": {
          "enabled": false,
          "dap_server": {
            "use_all": false,
            "servers": {
              "python": false,
              "codelldb": false
            }
          }
        },
        "neogen": false,
        "render_markdown": false,
        "venv-selector": false,
        "glance": false,
        "trouble": false,
        "inc_rename": false,
        "symbol_usage": false
